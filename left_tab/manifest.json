{
  "manifest_version": 3,
  "name": "Canvas Due Tracker",
  "version": "0.1.0",
  "description": "Tracks Canvas due dates and submitted status from assignment pages.",
  "permissions": ["storage", "activeTab", "alarms", "tabs"],
  "host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Canvas Due Tracker"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
