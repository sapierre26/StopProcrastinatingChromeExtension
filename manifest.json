{
  "manifest_version": 3,
  "name": "Stop Procrastinating: Alpaca Farm",
  "version": "0.1.0",
  "description": "Tracks Canvas assignments from Cal Poly Canvas and turns progress into an alpaca farm.",
  "permissions": ["storage", "windows", "notifications"],
  "host_permissions": ["https://canvas.calpoly.edu/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Alpaca Farm"
  },
  "content_scripts": [
    {
      "matches": ["https://canvas.calpoly.edu/*"],
      "js": ["canvas_integration/content.js"],
      "run_at": "document_idle"
    }
  ]
}
